{
  "name": "Store",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Store name"
    },
    "description": {
      "type": "string"
    },
    "owner_email": {
      "type": "string"
    },
    "owner_name": {
      "type": "string"
    },
    "logo_url": {
      "type": "string"
    },
    "banner_url": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "fashion",
        "electronics",
        "home",
        "beauty",
        "sports",
        "food",
        "art",
        "books",
        "handmade",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "pending",
        "suspended"
      ],
      "default": "pending"
    },
    "is_verified": {
      "type": "boolean",
      "default": false
    },
    "follower_count": {
      "type": "number",
      "default": 0
    },
    "product_count": {
      "type": "number",
      "default": 0
    },
    "total_sales": {
      "type": "number",
      "default": 0
    },
    "rating_avg": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "owner_email"
  ]
}